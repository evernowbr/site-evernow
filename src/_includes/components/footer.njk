{% set urlPrefix = "" if lang == "pt" else "/en" %}
<section>
  <div class="weight-footer-main-con bg-overly-img">
    <div class="container overlay-content">
      <div class="weight-footer-item-con">
        <div class="row wow fadeInUp">
          <!-- Logo + tagline -->
          <div class="col-lg-3 col-md-12 col-12 text-lg-left text-md-center mb-4 mb-lg-0">
            <div class="weight-footer-item">
              <figure><img src="/assets/image/logo/evernow-dark.png" alt="Evernow" class="img-fluid" style="max-width:160px;"></figure>
              <p class="mt-3" style="color:rgba(255,255,255,0.6);font-size:.88rem;line-height:1.6;">
                {% if lang == "en" %}Specialized cybersecurity consulting: AppSec, data protection, compliance and security operations.{% else %}Consultoria especializada em cibersegurança: AppSec, proteção de dados, compliance e operações de segurança.{% endif %}
              </p>
            </div>
          </div>

          <!-- Soluções / Solutions -->
          <div class="col-lg-2 col-md-3 col-6 mb-4 mb-lg-0">
            <div class="weight-footer-item">
              <h3 class="weight-footer-item-title" style="font-size:.9rem;text-transform:uppercase;letter-spacing:.06em;color:#00e0a3;margin-bottom:14px;">{{ "nav.solucoes" | t }}</h3>
              <ul class="list-unstyled mb-0" style="font-size:.88rem;">
                <li><a href="{{ urlPrefix }}/solucoes/secure-code/">Secure Code</a></li>
                <li><a href="{{ urlPrefix }}/solucoes/data-shield/">Data Shield</a></li>
                <li><a href="{{ urlPrefix }}/solucoes/assurance/">Assurance</a></li>
                <li><a href="{{ urlPrefix }}/solucoes/managed-ops/">Managed Ops</a></li>
              </ul>
            </div>
          </div>

          <!-- Indústrias / Industries + Recursos / Resources -->
          <div class="col-lg-2 col-md-3 col-6 mb-4 mb-lg-0">
            <div class="weight-footer-item">
              <h3 class="weight-footer-item-title" style="font-size:.9rem;text-transform:uppercase;letter-spacing:.06em;color:#00e0a3;margin-bottom:14px;">{{ "nav.industrias" | t }}</h3>
              <ul class="list-unstyled mb-0" style="font-size:.88rem;">
                <li><a href="{{ urlPrefix }}/{% if lang == 'en' %}industries/financial{% else %}industrias/financeiro{% endif %}/">{{ "nav.ind_financeiro" | t }}</a></li>
                <li><a href="{{ urlPrefix }}/{% if lang == 'en' %}industries/healthcare{% else %}industrias/saude{% endif %}/">{{ "nav.ind_saude" | t }}</a></li>
                <li><a href="{{ urlPrefix }}/{% if lang == 'en' %}industries/retail{% else %}industrias/varejo{% endif %}/">{{ "nav.ind_varejo" | t }}</a></li>
                <li><a href="{{ urlPrefix }}/{% if lang == 'en' %}industries/technology{% else %}industrias/tecnologia{% endif %}/">{{ "nav.ind_tecnologia" | t }}</a></li>
                <li><a href="{{ urlPrefix }}/{% if lang == 'en' %}industries/government{% else %}industrias/governo{% endif %}/">{{ "nav.ind_governo" | t }}</a></li>
              </ul>
            </div>
          </div>

          <!-- Recursos + Empresa -->
          <div class="col-lg-2 col-md-3 col-6 mb-4 mb-lg-0">
            <div class="weight-footer-item">
              <h3 style="font-size:.9rem;text-transform:uppercase;letter-spacing:.06em;color:#00e0a3;margin-bottom:14px;">{{ "nav.recursos" | t }}</h3>
              <ul class="list-unstyled mb-0" style="font-size:.88rem;">
                {% if lang != "en" %}<li><a href="{{ urlPrefix }}/blog">Blog</a></li>{% endif %}
                <li><a href="{{ urlPrefix }}/assessment">Assessment</a></li>
              </ul>
              <h3 style="font-size:.9rem;text-transform:uppercase;letter-spacing:.06em;color:#00e0a3;margin-bottom:14px;margin-top:20px;">{{ "nav.empresa" | t }}</h3>
              <ul class="list-unstyled mb-0" style="font-size:.88rem;">
                <li><a href="{{ urlPrefix }}/about">{{ "nav.sobre" | t }}</a></li>
                <li><a href="{{ urlPrefix }}/parceiros">{{ "nav.parceiros" | t }}</a></li>
              </ul>
            </div>
          </div>

          <!-- Contato / Contact -->
          <div class="col-lg-3 col-md-3 col-6">
            <div class="weight-footer-item">
              <h3 style="font-size:.9rem;text-transform:uppercase;letter-spacing:.06em;color:#00e0a3;margin-bottom:14px;">{{ "nav.contato" | t }}</h3>
              <ul class="list-unstyled mb-0" style="font-size:.88rem;">
                <li class="mb-2" style="color:rgba(255,255,255,0.6);">Rua Irmã Gabriela, 51<br>São Paulo / SP</li>
                <li><a href="mailto:contato@evernow.com.br">contato@evernow.com.br</a></li>
                <li><a href="tel:+5511910260404">+55 11 91026-0404</a></li>
                <li class="mt-3">
                  <a href="https://www.linkedin.com/company/evernowbr" style="margin-right:12px;" rel="noopener noreferrer" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                  <a href="https://www.instagram.com/evernowbr/" style="margin-right:12px;" rel="noopener noreferrer" target="_blank"><i class="fab fa-instagram"></i></a>
                  <a href="https://www.facebook.com/evernowbr" rel="noopener noreferrer" target="_blank"><i class="fab fa-facebook-f"></i></a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-con" style="border-top:1px solid rgba(255,255,255,0.07);margin-top:40px;">
      <div class="container overlay-content">
        <div class="row py-3 align-items-center">
          <div class="col-lg-6 text-center text-lg-left mb-2 mb-lg-0">
            <p style="font-size:.82rem;color:rgba(255,255,255,0.4);margin:0;">
              {% if lang == "en" %}Copyright Evernow © 2026. All rights reserved.{% else %}Copyright Evernow © 2026. Todos os direitos reservados.{% endif %}
            </p>
          </div>
          <div class="col-lg-6 text-center text-lg-right">
            <nav style="font-size:.82rem;">
              <a href="{{ urlPrefix }}/politica-de-privacidade" style="color:rgba(255,255,255,0.4);text-decoration:none;margin:0 10px;" onmouseover="this.style.color='#00e0a3'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">{% if lang == "en" %}Privacy Policy{% else %}Política de Privacidade{% endif %}</a>
              <span style="color:rgba(255,255,255,0.2);">·</span>
              <a href="{{ urlPrefix }}/termos-de-uso" style="color:rgba(255,255,255,0.4);text-decoration:none;margin:0 10px;" onmouseover="this.style.color='#00e0a3'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">{% if lang == "en" %}Terms of Use{% else %}Termos de Uso{% endif %}</a>
              <span style="color:rgba(255,255,255,0.2);">·</span>
              <a href="/sitemap.xml" style="color:rgba(255,255,255,0.4);text-decoration:none;margin:0 10px;" onmouseover="this.style.color='#00e0a3'" onmouseout="this.style.color='rgba(255,255,255,0.4)'" target="_blank">Sitemap</a>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
