{% set urlPrefix = "" if lang == "pt" else "/en" %}
<header>
  <div class="container">
    <div class="header-con">
      <nav class="navbar navbar-expand-lg navbar-light p-0">
        <a class="navbar-brand p-0" href="{{ urlPrefix }}/index.html">
          <img src="/assets/image/logo/evernow-dark.png" alt="Evernow" class="img-fluid">
        </a>
        <button class="navbar-toggler p-0 collapsed" type="button" data-toggle="collapse"
                data-target="#navbarMain" aria-controls="navbarMain"
                aria-expanded="false" aria-label="Alternar navegação">
          <span class="navbar-toggler-icon"></span>
          <span class="navbar-toggler-icon"></span>
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="navbarMain">
          <ul class="navbar-nav ev-nav">

            <!-- Empresa -->
            <li class="nav-item ev-dropdown {% if '/about' in page.url or '/parceiros' in page.url %}nav-item-active{% endif %}">
              <a class="nav-link text-white p-0 ev-dropdown__toggle" href="#" role="button">
                Empresa <i class="fas fa-chevron-down ev-dropdown__caret"></i>
              </a>
              <div class="ev-dropdown__menu">
                <div class="ev-dropdown__menu-inner">
                  <div class="ev-dropdown__grid ev-dropdown__grid--1">
                    <a class="ev-dropdown__item" href="/about.html">Sobre a Evernow</a>
                    <a class="ev-dropdown__item" href="/parceiros.html">Parceiros</a>
                    <a class="ev-dropdown__item" href="https://suporte.evernow.com.br" target="_blank" rel="noopener">Suporte</a>
                  </div>
                </div>
              </div>
            </li>

            <!-- Soluções -->
            <li class="nav-item ev-dropdown {% if '/solucoes' in page.url %}nav-item-active{% endif %}">
              <a class="nav-link text-white p-0 ev-dropdown__toggle" href="/solucoes/" role="button">
                Soluções <i class="fas fa-chevron-down ev-dropdown__caret"></i>
              </a>
              <div class="ev-dropdown__menu ev-dropdown__menu--medium">
                <div class="ev-dropdown__menu-inner">
                  <div class="ev-dropdown__grid ev-dropdown__grid--2">
                    <a class="ev-dropdown__item" href="/solucoes/secure-code/">
                      <strong>Secure Code</strong>
                      <span>Segurança em aplicações e DevSecOps</span>
                    </a>
                    <a class="ev-dropdown__item" href="/solucoes/data-shield/">
                      <strong>Data Shield</strong>
                      <span>Proteção e governança de dados</span>
                    </a>
                    <a class="ev-dropdown__item" href="/solucoes/assurance/">
                      <strong>Assurance</strong>
                      <span>Pentest, compliance e maturidade</span>
                    </a>
                    <a class="ev-dropdown__item" href="/solucoes/managed-ops/">
                      <strong>Managed Ops</strong>
                      <span>Serviços gerenciados e SOC</span>
                    </a>
                  </div>
                </div>
              </div>
            </li>

            <!-- Produtos -->
            <li class="nav-item ev-dropdown {% if '/produtos' in page.url %}nav-item-active{% endif %}">
              <a class="nav-link text-white p-0 ev-dropdown__toggle" href="/produtos/" role="button">
                Produtos <i class="fas fa-chevron-down ev-dropdown__caret"></i>
              </a>
              <div class="ev-dropdown__menu ev-dropdown__menu--wide">
                <div class="ev-dropdown__menu-inner">
                  <div class="ev-dropdown__section-title">Secure Code</div>
                  <div class="ev-dropdown__grid ev-dropdown__grid--3">
                    <a class="ev-dropdown__item" href="/produtos/devsecops/">DevSecOps</a>
                    <a class="ev-dropdown__item" href="/produtos/sast-dast-sca/">SAST / DAST / SCA</a>
                    <a class="ev-dropdown__item" href="/produtos/desenvolvimento-seguro-gerenciado/">Dev Seguro Gerenciado</a>
                    <a class="ev-dropdown__item" href="/produtos/modelagem-ameacas/">Modelagem de Ameaças</a>
                    <a class="ev-dropdown__item" href="/produtos/revisao-codigo/">Revisão de Código</a>
                    <a class="ev-dropdown__item" href="/produtos/treinamento-devsecops/">Treinamento DevSecOps</a>
                    <a class="ev-dropdown__item" href="/produtos/code-protection/">Code Protection</a>
                  </div>
                  <div class="ev-dropdown__section-title mt-3">Data Shield</div>
                  <div class="ev-dropdown__grid ev-dropdown__grid--3">
                    <a class="ev-dropdown__item" href="/produtos/data-discovery/">Data Discovery</a>
                    <a class="ev-dropdown__item" href="/produtos/dspm/">DSPM</a>
                    <a class="ev-dropdown__item" href="/produtos/criptografia-kms-hsm/">Criptografia / KMS / HSM</a>
                    <a class="ev-dropdown__item" href="/produtos/dlp/">DLP</a>
                    <a class="ev-dropdown__item" href="/produtos/consentimento-lgpd/">Consentimento & LGPD</a>
                    <a class="ev-dropdown__item" href="/produtos/cspm/">CSPM</a>
                  </div>
                  <div class="ev-dropdown__section-title mt-3">Assurance</div>
                  <div class="ev-dropdown__grid ev-dropdown__grid--3">
                    <a class="ev-dropdown__item" href="/produtos/pentest/">Pentest</a>
                    <a class="ev-dropdown__item" href="/produtos/red-team/">Red Team</a>
                    <a class="ev-dropdown__item" href="/produtos/assessment-maturidade/">Assessment de Maturidade</a>
                    <a class="ev-dropdown__item" href="/produtos/grc/">GRC</a>
                    <a class="ev-dropdown__item" href="/produtos/iso-27001/">ISO 27001</a>
                    <a class="ev-dropdown__item" href="/produtos/lgpd/">LGPD</a>
                    <a class="ev-dropdown__item" href="/produtos/pci-dss/">PCI DSS</a>
                  </div>
                  <div class="ev-dropdown__section-title mt-3">Managed Ops</div>
                  <div class="ev-dropdown__grid ev-dropdown__grid--3">
                    <a class="ev-dropdown__item" href="/produtos/servicos-gerenciados/">Serviços Gerenciados</a>
                    <a class="ev-dropdown__item" href="/produtos/soc-monitoramento/">SOC / Monitoramento</a>
                    <a class="ev-dropdown__item" href="/produtos/resposta-incidentes/">Resposta a Incidentes</a>
                    <a class="ev-dropdown__item" href="/produtos/gestao-vulnerabilidades/">Gestão de Vulnerabilidades</a>
                    <a class="ev-dropdown__item" href="/produtos/selecao-ferramentas/">Seleção de Ferramentas</a>
                    <a class="ev-dropdown__item" href="/produtos/pam/">PAM</a>
                  </div>
                </div>
              </div>
            </li>

            <!-- Indústrias -->
            <li class="nav-item ev-dropdown {% if '/industrias' in page.url %}nav-item-active{% endif %}">
              <a class="nav-link text-white p-0 ev-dropdown__toggle" href="/industrias/" role="button">
                Indústrias <i class="fas fa-chevron-down ev-dropdown__caret"></i>
              </a>
              <div class="ev-dropdown__menu">
                <div class="ev-dropdown__menu-inner">
                  <div class="ev-dropdown__grid ev-dropdown__grid--1">
                    <a class="ev-dropdown__item" href="/industrias/financeiro/">Financeiro</a>
                    <a class="ev-dropdown__item" href="/industrias/saude/">Saúde</a>
                    <a class="ev-dropdown__item" href="/industrias/varejo/">Varejo</a>
                    <a class="ev-dropdown__item" href="/industrias/tecnologia/">Tecnologia</a>
                    <a class="ev-dropdown__item" href="/industrias/governo/">Governo</a>
                  </div>
                </div>
              </div>
            </li>

            <!-- Recursos -->
            <li class="nav-item ev-dropdown {% if '/blog' in page.url or '/assessment' in page.url %}nav-item-active{% endif %}">
              <a class="nav-link text-white p-0 ev-dropdown__toggle" href="#" role="button">
                Recursos <i class="fas fa-chevron-down ev-dropdown__caret"></i>
              </a>
              <div class="ev-dropdown__menu">
                <div class="ev-dropdown__menu-inner">
                  <div class="ev-dropdown__grid ev-dropdown__grid--1">
                    <a class="ev-dropdown__item" href="/blog.html">Blog</a>
                    <a class="ev-dropdown__item" href="/assessment.html">Assessment</a>
                  </div>
                </div>
              </div>
            </li>

            <!-- Mobile: lang switcher -->
            <li class="nav-item d-lg-none mt-3">
              {% if lang == 'pt' %}
              <a href="/en{{ page.url }}" class="lang-flag-btn" data-set-lang="en" aria-label="Switch to English">
                <span class="lang-flag">🇺🇸</span><span class="lang-flag-text">EN</span>
              </a>
              {% else %}
              <a href="{{ page.url | replace('/en/', '/') }}" class="lang-flag-btn" data-set-lang="pt" aria-label="Mudar para Português">
                <span class="lang-flag">🇧🇷</span><span class="lang-flag-text">PT</span>
              </a>
              {% endif %}
            </li>
          </ul>

          <a href="/contact.html" class="my-2 my-sm-0 contact-btn ev-contact-btn">Contato</a>

          {% if lang == 'pt' %}
          <a href="/en{{ page.url }}" class="lang-flag-btn d-none d-lg-inline-flex" data-set-lang="en" aria-label="Switch to English">
            <span class="lang-flag">🇺🇸</span><span class="lang-flag-text">EN</span>
          </a>
          {% else %}
          <a href="{{ page.url | replace('/en/', '/') }}" class="lang-flag-btn d-none d-lg-inline-flex" data-set-lang="pt" aria-label="Mudar para Português">
            <span class="lang-flag">🇧🇷</span><span class="lang-flag-text">PT</span>
          </a>
          {% endif %}
        </div>
      </nav>
    </div>
  </div>
</header>
