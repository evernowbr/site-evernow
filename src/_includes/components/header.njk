{% set urlPrefix = "" if lang == "pt" else "/en" %}
<header>
   <!--navbar-start-->
   <div class="container">
      <div class="header-con">
         <nav class="navbar navbar-expand-lg navbar-light p-0">
            <a class="navbar-brand p-0" href="{{ urlPrefix }}/index.html">
               <img src="/assets/image/evernow-logo-bgescuro.png" alt="{% t 'aria.logoAlt' %}" class="img-fluid">
            </a>
            <button class="navbar-toggler p-0 collapsed" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="{% t 'nav.toggleLabel' %}">
               <span class="navbar-toggler-icon"></span>
               <span class="navbar-toggler-icon"></span>
               <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarSupportedContent">
               <ul class="navbar-nav">
                  <li class="nav-item">
                     <a class="nav-link {% if '/about' in page.url %}nav-link-active{% endif %} text-white p-0" href="{{ urlPrefix }}/about.html">{% t "nav.about" %}</a>
                  </li>
                  <li class="nav-item">
                     <a class="nav-link {% if '/services' in page.url %}nav-link-active{% endif %} text-white p-0" href="{{ urlPrefix }}/services.html"> {% t "nav.services" %} </a>
                  </li>
                  <li class="nav-item">
                     <a class="nav-link {% if '/solutions' in page.url %}nav-link-active{% endif %} text-white p-0" href="{{ urlPrefix }}/solutions.html"> {% t "nav.solutions" %} </a>
                  </li>
                  <li class="nav-item">
                     <a class="nav-link text-white p-0" href="https://suporte.evernow.com.br"> {% t "nav.support" %} </a>
                  </li>
                  <!-- Mobile: flag button inside collapsed menu -->
                  <li class="nav-item d-lg-none mt-3">
                     {% if lang == 'pt' %}
                     <a href="/en{{ page.url }}" class="lang-flag-btn" data-set-lang="en" aria-label="Switch to English">
                        <span class="lang-flag">🇺🇸</span><span class="lang-flag-text">EN</span>
                     </a>
                     {% else %}
                     <a href="{{ page.url | replace('/en/', '/') }}" class="lang-flag-btn" data-set-lang="pt" aria-label="Mudar para Português">
                        <span class="lang-flag">🇧🇷</span><span class="lang-flag-text">PT</span>
                     </a>
                     {% endif %}
                  </li>
               </ul>
               <a href="{{ urlPrefix }}/contact.html" class="my-2 my-sm-0 contact-btn"> {% t "nav.contact" %} </a>

               <!-- Desktop: flag button — shows only the other language -->
               {% if lang == 'pt' %}
               <a href="/en{{ page.url }}" class="lang-flag-btn d-none d-lg-inline-flex" data-set-lang="en" aria-label="Switch to English">
                  <span class="lang-flag">🇺🇸</span><span class="lang-flag-text">EN</span>
               </a>
               {% else %}
               <a href="{{ page.url | replace('/en/', '/') }}" class="lang-flag-btn d-none d-lg-inline-flex" data-set-lang="pt" aria-label="Mudar para Português">
                  <span class="lang-flag">🇧🇷</span><span class="lang-flag-text">PT</span>
               </a>
               {% endif %}
            </div>
         </nav>
      </div>
   </div>
   <!--navbar-end-->
</header>
