<section>
   <div class="Testimonials-section-con bg-overly-img"{% if testimonialsPaddingStyle %} style="padding: {{ testimonialsPaddingStyle }};"{% endif %}>
      <div class="container overlay-content">
         <div class="Testimonials-section-heading text-center">
            <h5>{{ testimonialsTagKey }}</h5>
            {% if testimonialsTitleKey %}
            <h2>{{ testimonialsTitleKey }}</h2>
            {% endif %}
         </div>

         {% if testimonialsLayout == 'single' %}
         {# Layout: depoimento único centralizado (ex: pentest) #}
         <div class="row wow slideInRight mt-5">
            <div class="col-lg-8 col-md-10 mx-auto">
               <div class="Testimonials-item-con">
                  <div class="Testimonials-item-content">
                     <p>"{{ testimonialsItem1Content }}"</p>
                  </div>
                  <div class="Testimonials-item-auter-con">
                     <div class="Testimonials-item-auter-heading">
                        <h6>{{ testimonialsItem1Author }}</h6>
                        <p class="mb-0">{{ testimonialsItem1Role }}</p>
                     </div>
                  </div>
               </div>
            </div>
         </div>

         {% else %}
         {# Layout padrão: carousel com dois depoimentos lado a lado (ex: home) #}
         <div id="carouselExampleIndicators" class="carousel slide wow slideInRight" data-ride="carousel">
            <div class="carousel-inner">
               <div class="carousel-item active">
                  <div class="row">
                     <div class="col-lg-6 col-md-6">
                        <div class="Testimonials-item-con">
                           <div class="Testimonials-item-content">
                              <p>{{ testimonialsItem1Content }}</p>
                           </div>
                           <div class="Testimonials-item-auter-con">
                              <div class="Testimonials-item-auter-heading">
                                 <h6>{{ testimonialsItem1Author }}</h6>
                                 <p class="mb-0">{{ testimonialsItem1Role }}</p>
                              </div>
                           </div>
                        </div>
                     </div>
                     <div class="col-lg-6 col-md-6">
                        <div class="Testimonials-item-con">
                           <div class="Testimonials-item-content">
                              <p>{{ testimonialsItem2Content }}</p>
                           </div>
                           <div class="Testimonials-item-auter-con">
                              <div class="Testimonials-item-auter-heading">
                                 <h6>{{ testimonialsItem2Author }}</h6>
                                 <p class="mb-0">{{ testimonialsItem2Role }}</p>
                              </div>
                           </div>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
         {% endif %}

      </div>
   </div>
</section>
