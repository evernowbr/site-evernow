<section class="logo-section">
   <div class="slider-con w-100">
      <div class="container">
         <div class="slider-heading text-center">
            <h5>{{ partnersTagKey }}</h5>
         </div>
         <div class="logo-scroller" aria-label="{{ partnersAriaLabel if partnersAriaLabel else 'Partner Logos' }}">
            <div class="logo-track">
               {% for i in range(1, 23) %}
               <div class="logo-item" aria-label="Partner {{ i }}">
                  <img src="/assets/image/parceiro-{{ i }}.png" alt="" loading="lazy" decoding="async">
               </div>
               {% endfor %}
            </div>
         </div>
      </div>
   </div>
</section>
