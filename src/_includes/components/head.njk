<!-- Language auto-detection: Brazil (pt-BR) → PT, rest of world → EN -->
<script>
(function () {
  try {
    var saved = localStorage.getItem('evernow-lang');
    var path   = window.location.pathname;
    var isEn   = path.startsWith('/en');
    var target;

    if (saved) {
      target = saved;
    } else {
      var bl = (navigator.language || navigator.userLanguage || 'pt').toLowerCase();
      target = bl.startsWith('pt') ? 'pt' : 'en';
      localStorage.setItem('evernow-lang', target);
    }

    if (target === 'en' && !isEn) {
      window.location.replace('/en' + path);
    } else if (target === 'pt' && isEn) {
      var ptPath = path.replace(/^\/en/, '') || '/';
      window.location.replace(ptPath);
    }
  } catch (e) {}
})();
</script>

