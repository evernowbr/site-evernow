<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta http-equiv="x-ua-compatible" content="ie=edge" />

<!-- SEO -->
{% if seoTitle %}
  <title>{{ seoTitle }}</title>
  <meta name="description" content="{{ seoDescription if seoDescription else seoTitle }}" />
{% elif pageMeta %}
  {% set _titleKey = "meta." + pageMeta + ".title" %}
  {% set _descKey  = "meta." + pageMeta + ".description" %}
  <title>{{ _titleKey | t }}</title>
  <meta name="description" content="{{ _descKey | t }}" />
{% else %}
  <title>{{ "meta.defaultTitle" | t }}</title>
  <meta name="description" content="{{ "meta.defaultDescription" | t }}" />
{% endif %}
<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
<link rel="canonical" href="https://evernow.com.br{{ page.url }}" />

<!-- Favicons / PWA -->
<meta name="theme-color" content="#00E0A3" />

<!-- Open Graph -->
<meta property="og:locale" content="{{ 'pt_BR' if lang == 'pt' else 'en_US' }}" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Evernow" />
<meta property="og:url" content="https://evernow.com.br{{ page.url }}" />
<meta property="og:title" content="{{ seoTitle if seoTitle else (_ogTitleKey | t if _ogTitleKey else ("meta.defaultTitle" | t)) }}" />
<meta property="og:description" content="{{ seoDescription if seoDescription else (_ogDescKey | t if _ogDescKey else ("meta.defaultDescription" | t)) }}" />
<meta property="og:image" content="https://evernow.com.br/assets/image/logo/evernow-dark.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@evernowbr" />
<meta name="twitter:title" content="{{ seoTitle if seoTitle else (_ogTitleKey | t if _ogTitleKey else ("meta.defaultTitle" | t)) }}" />
<meta name="twitter:description" content="{{ seoDescription if seoDescription else (_ogDescKey | t if _ogDescKey else ("meta.defaultDescription" | t)) }}" />

<link rel="stylesheet" href="/assets/css/main.min.css">
