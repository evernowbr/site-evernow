<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta http-equiv="x-ua-compatible" content="ie=edge" />

<!-- SEO -->
{% if seoTitle %}
  <title>{{ seoTitle }}</title>
  <meta name="description" content="{{ seoDescription if seoDescription else seoTitle }}" />
{% elif pageMeta %}
  {% set _titleKey = "meta." + pageMeta + ".title" %}
  {% set _descKey  = "meta." + pageMeta + ".description" %}
  <title>{{ _titleKey | t }}</title>
  <meta name="description" content="{{ _descKey | t }}" />
{% else %}
  <title>{{ "meta.defaultTitle" | t }}</title>
  <meta name="description" content="{{ "meta.defaultDescription" | t }}" />
{% endif %}
{# Keywords: prioridade seoKeywords front-matter → meta.<pageMeta>.keywords no i18n → default #}
{%- if seoKeywords -%}
  <meta name="keywords" content="{{ seoKeywords }}" />
{%- elif pageMeta -%}
  {%- set _kwKey = "meta." + pageMeta + ".keywords" -%}
  {%- set _kwValue = _kwKey | t -%}
  {%- if _kwValue and _kwValue != _kwKey -%}
  <meta name="keywords" content="{{ _kwValue }}" />
  {%- else -%}
  <meta name="keywords" content="{{ 'meta.defaultKeywords' | t }}" />
  {%- endif -%}
{%- else -%}
  <meta name="keywords" content="{{ 'meta.defaultKeywords' | t }}" />
{%- endif %}
<meta name="robots" content="{{ 'noindex,nofollow' if noIndex else 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1' }}" />
{# ── Canonical: strip de .html para todas as páginas exceto /404.html.
   Os permalinks estáticos geram URLs com .html; Cloudflare Pages serve a
   versão limpa e faz 301 (via _redirects). O canonical DEVE apontar para
   a URL limpa para evitar dispersão de PageRank.
   Posts de blog (/blog/slug.html) mantêm .html — decisão arquitetural.
#}
{%- set _canonical = page.url -%}
{%- if _canonical.endsWith('.html') and _canonical != '/404.html' and _canonical != '/en/404.html' -%}
  {%- set _canonical = _canonical | replace('.html', '') -%}
{%- endif -%}
<link rel="canonical" href="https://evernow.com.br{{ _canonical }}" />

<!-- hreflang (PT/EN bilíngue) -->
{%- if lang == 'pt' -%}
{%- set _hreflangEn = langEnUrl if langEnUrl else ('/en' + _canonical) -%}
<link rel="alternate" hreflang="pt-BR"    href="https://evernow.com.br{{ _canonical }}" />
<link rel="alternate" hreflang="en"       href="https://evernow.com.br{{ _hreflangEn }}" />
<link rel="alternate" hreflang="x-default" href="https://evernow.com.br{{ _canonical }}" />
{%- elif lang == 'en' -%}
{%- set _hreflangPt = langPtUrl if langPtUrl else (_canonical | replace('/en/', '/')) -%}
<link rel="alternate" hreflang="pt-BR"    href="https://evernow.com.br{{ _hreflangPt }}" />
<link rel="alternate" hreflang="en"       href="https://evernow.com.br{{ _canonical }}" />
<link rel="alternate" hreflang="x-default" href="https://evernow.com.br{{ _hreflangPt }}" />
{%- endif -%}

<!-- Favicons / PWA -->
<meta name="theme-color" content="#00E0A3" />

<!-- Open Graph -->
{%- set _ogImage = seoImage if seoImage else "https://evernow.com.br/assets/image/logo/evernow-og.png" -%}
{%- if seoTitle -%}
  {%- set _ogTitle = seoTitle -%}
{%- elif _ogTitleKey -%}
  {%- set _ogTitle = _ogTitleKey | t -%}
{%- elif pageMeta -%}
  {%- set _ogTitle = ("meta." + pageMeta + ".ogTitle") | t -%}
{%- else -%}
  {%- set _ogTitle = "meta.defaultTitle" | t -%}
{%- endif -%}
{%- if seoDescription -%}
  {%- set _ogDesc = seoDescription -%}
{%- elif _ogDescKey -%}
  {%- set _ogDesc = _ogDescKey | t -%}
{%- elif pageMeta -%}
  {%- set _ogDesc = ("meta." + pageMeta + ".ogDescription") | t -%}
{%- else -%}
  {%- set _ogDesc = "meta.defaultDescription" | t -%}
{%- endif -%}
<meta property="og:locale"      content="{{ 'pt_BR' if lang == 'pt' else 'en_US' }}" />
<meta property="og:type"        content="website" />
<meta property="og:site_name"   content="Evernow" />
<meta property="og:url"         content="https://evernow.com.br{{ _canonical }}" />
<meta property="og:title"       content="{{ _ogTitle }}" />
<meta property="og:description" content="{{ _ogDesc }}" />
<meta property="og:image"       content="{{ _ogImage }}" />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt"    content="{{ _ogTitle }}" />

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:site"        content="@evernowbr" />
<meta name="twitter:title"       content="{{ _ogTitle }}" />
<meta name="twitter:description" content="{{ _ogDesc }}" />
<meta name="twitter:image"       content="{{ _ogImage }}" />
<meta name="twitter:image:alt"   content="{{ _ogTitle }}" />

<!-- Preload LCP image (homepage only) -->
{%- if pageMeta == 'home' -%}
<link rel="preload" as="image" href="/assets/image/hero/main.png" fetchpriority="high">
{%- endif -%}

