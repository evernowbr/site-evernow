{
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": "{% if lang == 'en' %}DevSecOps: the complete 2026 guide{% else %}DevSecOps: o guia completo de 2026{% endif %}",
  "description": "{% if lang == 'en' %}What DevSecOps is, how to implement it across the CI/CD pipeline, executive KPIs and common mistakes.{% else %}O que é DevSecOps, como implementar no pipeline CI/CD, KPIs executivos e erros comuns.{% endif %}",
  "author": { "@type": "Organization", "name": "Evernow", "url": "https://evernow.com.br" },
  "publisher": {
    "@type": "Organization",
    "name": "Evernow",
    "logo": { "@type": "ImageObject", "url": "https://evernow.com.br/assets/image/logo/evernow-dark.png" }
  },
  "datePublished": "2026-04-22",
  "inLanguage": "{% if lang == 'en' %}en{% else %}pt-BR{% endif %}",
  "mainEntityOfPage": "https://evernow.com.br{% if lang == 'en' %}/en/guides/devsecops/{% else %}/guias/devsecops/{% endif %}"
}
</script>
