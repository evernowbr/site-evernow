---
layout: layouts/base.njk
pagination:
  data: languages
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/en/guides/cspm/{% else %}/guias/cspm-o-que-e/{% endif %}"
seoTitle: "CSPM: O que é Cloud Security Posture Management e Como Implementar | Evernow"
seoDescription: "Guia completo de CSPM em 2026: diferença de CSPM vs CNAPP vs CWPP, os 8 controles essenciais, integração AWS/Azure/GCP e como priorizar findings na prática."
seoKeywords: "cspm, cloud security posture management, o que é cspm, cspm brasil, cspm vs cnapp, cspm vs cwpp, misconfiguração cloud, segurança aws azure gcp"
langPtUrl: "/guias/cspm-o-que-e/"
langEnUrl: "/en/guides/cspm/"
---
{% set urlPrefix = "" if lang == "pt" else "/en" %}
{% set langPtUrl = "/guias/cspm-o-que-e/" %}
{% set langEnUrl = "/en/guides/cspm/" %}
{% set breadcrumbs = [
  { label: ("Home" if lang == "en" else "Início"), url: urlPrefix + "/" },
  { label: ("Guides" if lang == "en" else "Guias"), url: urlPrefix + "/guias/" },
  { label: "CSPM" }
] %}

<div class="header-and-banner-con w-100">
  <div class="header-and-banner-inner-con overlay-content">
    {% include "components/header.njk" %}
    {% include "components/breadcrumbs.njk" %}

    <section class="banner-main-con ev-hero" style="padding:60px 0 50px;">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-7 wow slideInLeft">
            <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:18px;">
              <span style="background:rgba(0,224,163,.12);border:1px solid rgba(0,224,163,.3);color:#00e0a3;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;padding:4px 12px;border-radius:20px;">{% if lang == "en" %}Guide · Cloud Security{% else %}Guia · Cloud Security{% endif %}</span>
              <span style="color:rgba(255,255,255,.4);font-size:.78rem;"><i class="fas fa-clock" style="margin-right:5px;"></i>{% if lang == "en" %}11 min read{% else %}11 min de leitura{% endif %}</span>
              <span style="color:rgba(255,255,255,.4);font-size:.78rem;"><i class="fas fa-calendar-alt" style="margin-right:5px;"></i>{% if lang == "en" %}Updated Apr 2026{% else %}Atualizado Abr 2026{% endif %}</span>
            </div>
            <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;line-height:1.15;">
              {% if lang == "en" %}CSPM: what it is, when you need it, <span style="color:#00e0a3;">and how to implement it</span>{% else %}CSPM: o que é, quando você precisa <span style="color:#00e0a3;">e como implementar</span>{% endif %}
            </h1>
            <p class="ev-hero__sub mt-3">
              {% if lang == "en" %}Cloud Security Posture Management explained without buzzword: 8 essential controls, difference vs CWPP and CNAPP, how to prioritize findings and turn noise into actionable tickets.{% else %}Cloud Security Posture Management explicado sem buzzword: 8 controles essenciais, diferença para CWPP e CNAPP, como priorizar achados e transformar ruído em ticket acionável.{% endif %}
            </p>
            <div class="ev-hero__trust mt-4">
              <span class="ev-hero__trust-item"><i class="fas fa-check-circle"></i> AWS · Azure · GCP</span>
              <span class="ev-hero__trust-item"><i class="fas fa-check-circle"></i> CSPM vs CWPP vs CNAPP</span>
              <span class="ev-hero__trust-item"><i class="fas fa-check-circle"></i> {% if lang == "en" %}Noise prioritization{% else %}Priorização de ruído{% endif %}</span>
            </div>
            <div class="mt-4 d-flex flex-wrap" style="gap:14px;">
              <a href="{{ urlPrefix }}/contact.html" class="contact-btn">{% if lang == "en" %}Talk to a cloud specialist{% else %}Fale com especialista cloud{% endif %}</a>
              <a href="{{ urlPrefix }}/produtos/cspm/" class="ev-btn-outline">{% if lang == "en" %}See managed CSPM{% else %}Ver CSPM gerenciado{% endif %}</a>
            </div>
          </div>

          <div class="col-lg-5 wow slideInRight mt-5 mt-lg-0">
            <div style="background:rgba(255,255,255,.05);border:1px solid rgba(0,224,163,.2);border-radius:14px;padding:28px;">
              <p style="color:#00e0a3;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:16px;">{% if lang == "en" %}8 controls that matter{% else %}8 controles que importam{% endif %}</p>
              <div style="display:flex;flex-direction:column;gap:8px;">
                {% set controls = ["Public data exposure", "Exposed network ports", "IAM / CIEM", "Encryption at rest / transit", "Audit logging", "Kubernetes", "Benchmark drift", "IaC pre-deploy scan"] %}
                {% set controls_pt = ["Exposição pública de dados", "Portas de rede expostas", "IAM / CIEM", "Criptografia em repouso / trânsito", "Logging de auditoria", "Kubernetes", "Drift de benchmark", "Scan IaC pré-deploy"] %}
                {% for c in controls %}
                <div style="display:flex;align-items:center;gap:10px;">
                  <span style="min-width:22px;height:22px;background:rgba(0,224,163,.15);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:800;color:#00e0a3;">{{ loop.index }}</span>
                  <span style="font-size:.85rem;color:rgba(255,255,255,.75);">{{ controls_pt[loop.index0] if lang == "pt" else c }}</span>
                </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

<main>

  <!-- DEFINIÇÃO -->
  <section class="ev-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-10 mx-auto">
          <div class="ev-section__tag wow fadeInUp">{% if lang == "en" %}Definition{% else %}Definição{% endif %}</div>
          <h2 class="ev-section__title wow fadeInUp">{% if lang == "en" %}What is CSPM (without buzzword){% else %}O que é CSPM (sem buzzword){% endif %}</h2>
          <div style="background:rgba(0,224,163,.06);border-left:4px solid #00e0a3;border-radius:0 12px 12px 0;padding:24px 28px;margin:24px 0 20px;" class="wow fadeInUp">
            <p style="font-size:1.05rem;color:rgba(255,255,255,.9);line-height:1.75;margin:0;">{% if lang == "en" %}CSPM (Cloud Security Posture Management) is a platform that continuously audits the configuration of your cloud accounts (AWS, Azure, GCP, OCI) against security benchmarks, finds misconfigurations, and prioritizes what to fix first.{% else %}CSPM (Cloud Security Posture Management) é uma plataforma que audita continuamente a configuração das suas contas cloud (AWS, Azure, GCP, OCI) contra benchmarks de segurança, encontra misconfigurations e prioriza o que corrigir primeiro.{% endif %}</p>
          </div>
          <p style="color:rgba(255,255,255,.7);line-height:1.75;margin-top:16px;">{% if lang == "en" %}In practice: "is this S3 bucket public? Does this security group have port 22 open to the internet? Is RDS encrypted? Is CloudTrail enabled in all regions?" Multiply by 12k+ resources in a typical environment and you understand why nobody checks manually.{% else %}Na prática: "esse bucket S3 está público? Esse security group tem porta 22 aberta pra internet? O RDS está criptografado? O CloudTrail está ativo em todas regiões?" Multiplique por 12k+ recursos de um ambiente típico e você entende por que ninguém checa na mão.{% endif %}</p>
          <p style="color:rgba(255,255,255,.6);line-height:1.75;margin-top:12px;">{% if lang == "en" %}It is <strong>not</strong>: EDR, WAF, SIEM, DLP or code scanner. CSPM only looks at cloud control plane configuration. Stops where the workload starts.{% else %}Não é: EDR, WAF, SIEM, DLP nem code scanner. CSPM só olha a configuração do plano de controle cloud. Para onde começa o workload.{% endif %}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CSPM vs CWPP vs CNAPP -->
  <section class="ev-section ev-section--alt">
    <div class="container">
      <div class="ev-section__tag wow fadeInUp">{% if lang == "en" %}Where it fits{% else %}Onde entra{% endif %}</div>
      <h2 class="ev-section__title wow fadeInUp">CSPM vs CWPP vs CNAPP</h2>
      <div class="row mt-5">
        <div class="col-lg-4 mb-4 wow fadeInUp">
          <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:28px;height:100%;position:relative;overflow:hidden;">
            <div style="position:absolute;top:0;left:0;width:4px;height:100%;background:#00e0a3;border-radius:14px 0 0 14px;"></div>
            <div style="width:44px;height:44px;background:rgba(0,224,163,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
              <i class="fas fa-sliders-h" style="color:#00e0a3;font-size:1.1rem;"></i>
            </div>
            <h4 style="color:#00e0a3;font-size:1.2rem;font-weight:800;margin-bottom:4px;">CSPM</h4>
            <p style="font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.5);margin-bottom:14px;">{% if lang == "en" %}Control plane{% else %}Plano de controle{% endif %}</p>
            <p style="color:rgba(255,255,255,.8);line-height:1.7;">{% if lang == "en" %}<strong>Configuration</strong> of the cloud account. Finds: public buckets, open ports, non-rotated keys, missing MFA, drift from benchmarks.{% else %}<strong>Configuração</strong> da conta cloud. Encontra: buckets públicos, portas abertas, chaves sem rotação, MFA ausente, drift de benchmark.{% endif %}</p>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,.08);">
              <p style="font-size:.82rem;color:rgba(255,255,255,.5);margin:0;"><strong style="color:rgba(255,255,255,.6);">{% if lang == "en" %}Reads:{% else %}Lê:{% endif %}</strong> CloudTrail, Config, Azure Activity, GCP Audit</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 mb-4 wow fadeInUp">
          <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:28px;height:100%;position:relative;overflow:hidden;">
            <div style="position:absolute;top:0;left:0;width:4px;height:100%;background:#5b8fff;border-radius:14px 0 0 14px;"></div>
            <div style="width:44px;height:44px;background:rgba(91,143,255,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
              <i class="fas fa-server" style="color:#5b8fff;font-size:1.1rem;"></i>
            </div>
            <h4 style="color:#5b8fff;font-size:1.2rem;font-weight:800;margin-bottom:4px;">CWPP</h4>
            <p style="font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.5);margin-bottom:14px;">{% if lang == "en" %}Workload plane{% else %}Plano de workload{% endif %}</p>
            <p style="color:rgba(255,255,255,.8);line-height:1.7;">{% if lang == "en" %}<strong>Content</strong> of the workload. Finds: vulnerabilities in containers, malware in VMs, non-compliant runtime, dangerous processes.{% else %}<strong>Conteúdo</strong> do workload. Encontra: vulnerabilidades em contêineres, malware em VM, runtime não-conforme, processos perigosos.{% endif %}</p>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,.08);">
              <p style="font-size:.82rem;color:rgba(255,255,255,.5);margin:0;"><strong style="color:rgba(255,255,255,.6);">{% if lang == "en" %}Reads:{% else %}Lê:{% endif %}</strong> {% if lang == "en" %}container images, VM processes, Kubernetes pods{% else %}imagens de contêiner, processos de VM, pods Kubernetes{% endif %}</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 mb-4 wow fadeInUp">
          <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:28px;height:100%;position:relative;overflow:hidden;">
            <div style="position:absolute;top:0;left:0;width:4px;height:100%;background:#a855f7;border-radius:14px 0 0 14px;"></div>
            <div style="width:44px;height:44px;background:rgba(168,85,247,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
              <i class="fas fa-layer-group" style="color:#a855f7;font-size:1.1rem;"></i>
            </div>
            <h4 style="color:#a855f7;font-size:1.2rem;font-weight:800;margin-bottom:4px;">CNAPP</h4>
            <p style="font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.5);margin-bottom:14px;">{% if lang == "en" %}Unified{% else %}Unificado{% endif %}</p>
            <p style="color:rgba(255,255,255,.8);line-height:1.7;">{% if lang == "en" %}Consolidation of CSPM + CWPP + CIEM + IaC scanning + Kubernetes security in a single platform. Trend since 2024.{% else %}Consolidação de CSPM + CWPP + CIEM + IaC scanning + Kubernetes security em plataforma única. Tendência desde 2024.{% endif %}</p>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,.08);">
              <p style="font-size:.82rem;color:rgba(255,255,255,.5);margin:0;"><strong style="color:rgba(255,255,255,.6);">{% if lang == "en" %}Examples:{% else %}Exemplos:{% endif %}</strong> Orca, Wiz, Prisma Cloud, Defender CSPM</p>
            </div>
          </div>
        </div>
      </div>
      <div style="background:rgba(0,224,163,.06);border-left:4px solid #00e0a3;border-radius:0 10px 10px 0;padding:16px 20px;margin-top:8px;" class="wow fadeInUp">
        <p style="margin:0;color:rgba(255,255,255,.8);font-size:.92rem;line-height:1.7;">💡 {% if lang == "en" %}<strong>Pragmatic recommendation</strong> for a medium-large environment: start with CSPM, add CWPP in 6 months, consolidate to CNAPP in year 2 if the budget allows.{% else %}<strong>Recomendação pragmática</strong> para ambiente médio-grande: comece por CSPM, some CWPP em 6 meses, consolide em CNAPP no ano 2 se orçamento permitir.{% endif %}</p>
      </div>
    </div>
  </section>

  <!-- 8 CONTROLES -->
  <section class="ev-section bg-overly-img">
    <div class="container overlay-content">
      <div class="ev-section__tag wow fadeInUp">{% if lang == "en" %}What to monitor{% else %}O que monitorar{% endif %}</div>
      <h2 class="ev-section__title wow fadeInUp">{% if lang == "en" %}8 CSPM controls that matter (above the noise){% else %}8 controles CSPM que importam (acima do ruído){% endif %}</h2>
      <p class="ev-section__desc wow fadeInUp mb-5">{% if lang == "en" %}Focus here first — these are the controls with the highest blast radius.{% else %}Comece aqui — são os controles com maior raio de explosão em caso de falha.{% endif %}</p>
      <div class="ev-delivery-grid">
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-unlock-alt"></i></div><h4>1. {% if lang == "en" %}Public data exposure{% else %}Exposição pública de dados{% endif %}</h4><p>{% if lang == "en" %}Public S3/Blob/GCS buckets, public RDS snapshots, anonymous access to storage, public Kubernetes dashboards.{% else %}Buckets S3/Blob/GCS públicos, snapshots RDS públicos, acesso anônimo a storage, dashboards Kubernetes públicos.{% endif %}</p></div>
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-network-wired"></i></div><h4>2. {% if lang == "en" %}Exposed network{% else %}Rede exposta{% endif %}</h4><p>{% if lang == "en" %}Security groups with 0.0.0.0/0 on sensitive ports (22, 3389, 3306, 5432, 6379, 27017, 9200).{% else %}Security groups com 0.0.0.0/0 em portas sensíveis (22, 3389, 3306, 5432, 6379, 27017, 9200).{% endif %}</p></div>
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-key"></i></div><h4>3. IAM / CIEM</h4><p>{% if lang == "en" %}Root account without MFA, access keys older than 90 days, excessive permissions, wide wildcards, long-lived service accounts.{% else %}Root account sem MFA, access keys com mais de 90 dias, permissões excessivas, wildcards amplos, service accounts de longa duração.{% endif %}</p></div>
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-lock"></i></div><h4>4. {% if lang == "en" %}Encryption{% else %}Criptografia{% endif %}</h4><p>{% if lang == "en" %}EBS, RDS, S3, Blob without encryption, TLS &lt; 1.2, non-rotated KMS keys, insecure internal traffic.{% else %}EBS, RDS, S3, Blob sem criptografia, TLS &lt; 1.2, chaves KMS sem rotação, tráfego interno inseguro.{% endif %}</p></div>
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-history"></i></div><h4>5. {% if lang == "en" %}Audit logging{% else %}Logging de auditoria{% endif %}</h4><p>{% if lang == "en" %}CloudTrail / Activity Log / Audit Log off or sending to non-protected destination, log retention below compliance.{% else %}CloudTrail / Activity Log / Audit Log desligado ou enviando a destino sem proteção, retenção abaixo do compliance.{% endif %}</p></div>
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-cubes"></i></div><h4>6. Kubernetes</h4><p>{% if lang == "en" %}API Server exposed, no Pod Security Admission, open Tiller, privileged pods, Secrets as plaintext environment variables.{% else %}API Server exposto, sem Pod Security Admission, Tiller aberto, privileged pods, Secrets como env vars em texto puro.{% endif %}</p></div>
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-exclamation-circle"></i></div><h4>7. {% if lang == "en" %}Benchmark drift{% else %}Drift de benchmark{% endif %}</h4><p>{% if lang == "en" %}Gap vs CIS AWS Foundations, Azure CIS, GCP CIS, NIST SP 800-53, PCI-DSS, LGPD, ISO 27001.{% else %}Distanciamento do CIS AWS Foundations, Azure CIS, GCP CIS, NIST SP 800-53, PCI-DSS, LGPD, ISO 27001.{% endif %}</p></div>
        <div class="ev-delivery-card wow fadeInUp"><div class="ev-delivery-card__icon"><i class="fas fa-file-code"></i></div><h4>8. IaC</h4><p>{% if lang == "en" %}Pre-deploy scan of Terraform / CloudFormation / ARM / Bicep / Pulumi with Checkov, tfsec, Terrascan to prevent misconfig from being born.{% else %}Scan pré-deploy de Terraform / CloudFormation / ARM / Bicep / Pulumi com Checkov, tfsec, Terrascan para impedir misconfig de nascer.{% endif %}</p></div>
      </div>
    </div>
  </section>

  <!-- MID-PAGE CTA -->
  <section style="background:linear-gradient(90deg,rgba(0,224,163,.12) 0%,rgba(0,224,163,.03) 100%);border-top:1px solid rgba(0,224,163,.2);border-bottom:1px solid rgba(0,224,163,.2);padding:40px 0;">
    <div class="container overlay-content">
      <div class="row align-items-center">
        <div class="col-lg-8 mb-4 mb-lg-0">
          <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:8px;color:#fff;">
            {% if lang == "en" %}Want to see the top-5 critical risks in your cloud today?{% else %}Quer ver os 5 maiores riscos críticos no seu cloud hoje?{% endif %}
          </h3>
          <p style="color:rgba(255,255,255,.7);margin:0;font-size:.95rem;">
            {% if lang == "en" %}Free 30-minute cloud diagnosis — no tools to install, no commitment.{% else %}30 min gratuitos de diagnóstico cloud — sem ferramenta para instalar, sem compromisso.{% endif %}
          </p>
        </div>
        <div class="col-lg-4 text-lg-right">
          <a href="{{ urlPrefix }}/contact.html" class="contact-btn">{% if lang == "en" %}Request diagnosis{% else %}Solicitar diagnóstico{% endif %}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PRIORIZAÇÃO -->
  <section class="ev-section ev-section--alt">
    <div class="container">
      <div class="ev-section__tag wow fadeInUp">{% if lang == "en" %}Fighting noise{% else %}Combatendo o ruído{% endif %}</div>
      <h2 class="ev-section__title wow fadeInUp">{% if lang == "en" %}How to prioritize 5,000 findings{% else %}Como priorizar 5.000 findings{% endif %}</h2>
      <p class="ev-section__desc wow fadeInUp">{% if lang == "en" %}Every modern CSPM returns thousands of findings on day 1. The mistake is opening all of them as tickets.{% else %}Todo CSPM moderno retorna milhares de findings no dia 1. O erro é abrir todos como ticket.{% endif %}</p>
      <div class="row mt-5">
        <div class="col-lg-10 mx-auto">
          {% set dims = [
            { name: "Dim 1 — Blast radius", desc_pt: "A misconfiguração permite chegar a dado pessoal (LGPD), a dinheiro (sistemas de pagamento) ou ao plano de controle (root)? Sim → crítico independente de CVSS.", desc_en: "Does the misconfiguration allow reaching personal data (LGPD), money (payment systems), or the control plane (root)? Yes → critical regardless of CVSS." },
            { name: "Dim 2 — Exploitable today", name_pt: "Dim 2 — Explorável hoje", desc_pt: "Está alcançável da internet e o exploit é público? Sim → prioridade máxima.", desc_en: "Is it reachable from the internet and the exploit is public? Yes → highest priority." },
            { name: "Dim 3 — Effort", name_pt: "Dim 3 — Esforço", desc_pt: "A correção é um PR de IaC de 3 linhas ou uma migração de dado? Agrupe correções similares no mesmo sprint para otimizar esforço.", desc_en: "Is the fix an IaC PR of 3 lines or a data-level migration? Cluster similar fixes in the same sprint to optimize effort." },
            { name: "Result", name_pt: "Resultado", desc_pt: "5.000 findings viram ~120 tickets acionáveis na semana 1, 40 na semana 3, < 20 na semana 6. Auto-supressão de findings em ambientes não-produtivos.", desc_en: "5,000 findings become ~120 actionable tickets in week 1, 40 in week 3, < 20 in week 6. Auto-suppression of findings in non-production environments." }
          ] %}
          <div style="display:flex;flex-direction:column;gap:12px;">
            {% for dim in dims %}
            <div class="wow fadeInUp" style="display:flex;align-items:flex-start;gap:16px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:18px 22px;transition:border-color .2s,background .2s;" onmouseover="this.style.borderColor='rgba(0,224,163,.25)';this.style.background='rgba(0,224,163,.05)'" onmouseout="this.style.borderColor='rgba(255,255,255,.07)';this.style.background='rgba(255,255,255,.03)'">
              <div style="min-width:32px;height:32px;background:rgba(0,224,163,.15);border:1px solid rgba(0,224,163,.3);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span style="color:#00e0a3;font-weight:800;font-size:.82rem;">{{ loop.index }}</span>
              </div>
              <div style="padding-top:4px;">
                <strong style="color:#00e0a3;font-size:.95rem;">{{ (dim.name_pt if dim.name_pt else dim.name) if lang == "pt" else dim.name }}</strong>
                <span style="color:rgba(255,255,255,.65);font-size:.9rem;"> — {{ dim.desc_pt if lang == "pt" else dim.desc_en }}</span>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FERRAMENTAS -->
  <section class="ev-section bg-overly-img">
    <div class="container overlay-content">
      <div class="ev-section__tag wow fadeInUp">Tooling</div>
      <h2 class="ev-section__title wow fadeInUp">{% if lang == "en" %}Platforms Evernow deploys in production{% else %}Plataformas que a Evernow implanta em produção{% endif %}</h2>
      <div class="ev-related-grid mt-4">
        <a href="{{ urlPrefix }}/parceiros/orca-security/" class="ev-related-card wow fadeInUp">
