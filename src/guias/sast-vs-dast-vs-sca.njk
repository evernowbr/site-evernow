              <div class="banner-left-con wow slideInLeft">
                <p style="color:#00e0a3;font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;font-weight:700;margin-bottom:12px;">{% if lang == "en" %}Guide · AppSec{% else %}Guia · AppSec{% endif %}</p>
