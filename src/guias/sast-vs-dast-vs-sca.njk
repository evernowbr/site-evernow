        <div class="col-md-4 mb-4">
          <a href="{{ urlPrefix }}/produtos/sast-dast-sca/" style="display:block;background:rgba(0,224,163,.08);border:1px solid rgba(0,224,163,.3);border-radius:10px;padding:24px;text-decoration:none;height:100%;">
            <h5 style="color:#00e0a3;">{% if lang == "en" %}→ Managed service{% else %}→ Serviço gerenciado{% endif %}</h5>
            <p style="color:rgba(255,255,255,.75);font-size:.9rem;">{% if lang == "en" %}Evernow designs, deploys and operates your full SAST/DAST/SCA program.{% else %}A Evernow projeta, implanta e opera seu programa completo SAST/DAST/SCA.{% endif %}</p>
