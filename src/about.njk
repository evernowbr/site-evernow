---
layout: layouts/base.njk
pagination:
  data: languages
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/en/{% endif %}about.html"
pageMeta: about
---
{% set urlPrefix = "" if lang == "pt" else "/en" %}
<div class="header-and-banner-con w-100">
   <div class="header-and-banner-inner-con overlay-content">
      {% include "components/header.njk" %}
      
      <section class="banner-main-con about-page-main-banner-con">
         <div class="container">
            <div class="banner-con about-page-banner-con text-center">
               <div class="row wow slideInLeft">
                  <div class="col-lg-12">
                     <div class="about-page-banner-title">
                        <h1>{{ "about.banner.title" | t }}</h1>
                        <p class="mb-0">{{ "about.banner.subtitle" | t }}</p>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </section>

      <!--- blog-post-section-->
      <section>
         <div class="Effective-con about-features-con padding_top_120 padding_bottom_65">
         <div class="container">
            <div class="blog-post-details-con">
               <div class="row">
                  <div class="col-lg-4 col-md-4 col-sm-4 col-12 mb-lg-0 mb-md-0 mb-sm-0 mb-4 wow slideInRight">
                     <div class="blog-post-details-sec-img float-left">
                        <img src="/assets/image/icon/checkbox.png" alt="check-box-icon" class="img-fluid" loading="lazy">
                     </div>
                     <div class="blog-post-details-heading-sec">
                        <div class="blog-post-details-sec-title">
                           <h4>{{ "about.features.item1.title" | t }}</h4>
                        </div>
                        <div class="blog-post-details-sec-content">
                           <p class="mb-0">{{ "about.features.item1.desc" | t }}</p>
                        </div>
                     </div>
                  </div>
                  <div class="col-lg-4 col-md-4 col-sm-4 col-12 mb-lg-0 mb-md-0 md-sm-0 mb-4 wow slideInRight">
                     <div class="blog-post-details-sec-img float-left">
                        <img src="/assets/image/icon/checkbox.png" alt="check-box-icon" class="img-fluid" loading="lazy">
                     </div>
                     <div class="blog-post-details-heading-sec">
                        <div class="blog-post-details-sec-title">
                           <h4>{{ "about.features.item2.title" | t }}</h4>
                        </div>
                        <div class="blog-post-details-sec-content">
                           <p class="mb-0">{{ "about.features.item2.desc" | t }}</p>
                        </div>
                     </div>
                  </div>
                  <div class="col-lg-4 col-md-4 col-sm-4 col-12 wow slideInRight">
                     <div class="blog-post-details-sec-img float-left">
                        <img src="/assets/image/icon/checkbox.png" alt="check-box-icon" class="img-fluid" loading="lazy">
                     </div>
                     <div class="blog-post-details-heading-sec">
                        <div class="blog-post-details-sec-title">
                           <h4>{{ "about.features.item3.title" | t }}</h4>
                        </div>
                        <div class="blog-post-details-sec-content">
                           <p class="mb-0">{{ "about.features.item3.desc" | t }}</p>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </div>
      </section>
   </div>
</div>

<main>
   <!---slider-section-->
   {% set partnersTagKey = "about.partners.tag" | t %}
   {% set partnersSliderExtraClass = "about-slider-con" %}
   {% include "components/partners-grid.njk" %}

   <!---information-section-->
   <section>
      <div class="informationmain-con dots-left-img information-about-page-con w-100 pt-0">
         <div class="container overlay-content">
            <div class="row">
               <div class="col-lg-6 col-md-6 col-sm-12 informationmain-left-con wow slideInLeft">
                  <div class="informationmainleft-sec-img">
                     <figure class="mb-0">
                        <img src="/assets/image/service/info-about-left.png" alt="informationmain-about-page-left-sec-img" loading="lazy">
                     </figure>
                  </div>
               </div>
               <div class="col-lg-6 col-md-6 col-sm-12 informationmain-right-con wow slideInRight">
                  <div class="informationmain-right-heading">
                     <h5>{{ "about.how_we_work.tag" | t }}</h5>
                     <h2>{{ "about.how_we_work.title" | t | safe }}</h2>
                  </div>
                  <div class="informationmain-right-content">
                     <p>{{ "about.how_we_work.desc" | t }}</p>
                     <ul class="mb-0 list">
                        <li><i class="fas fa-check-circle"></i>{{ "about.how_we_work.li1" | t | safe }}</li>
                        <li><i class="fas fa-check-circle"></i>{{ "about.how_we_work.li2" | t | safe }}</li>
                        <li><i class="fas fa-check-circle"></i>{{ "about.how_we_work.li3" | t | safe }}</li>
                        <li><i class="fas fa-check-circle"></i>{{ "about.how_we_work.li4" | t | safe }}</li>
                        <li><i class="fas fa-check-circle"></i>{{ "about.how_we_work.li5" | t | safe }}</li>
                     </ul>
                  </div>
               </div>
            </div>
         </div>
      </div>
   </section>

   <!---Cyber-Security-section-->
   <section>
      <div class="Cyber-Security-con about-page-Cyber-main-con bg-overly-img w-100">
         <div class="container overlay-content">
            <div class="row wow fadeInUp">
               <div class="col-lg-12">
                  <div class="about-pillars-header text-center mb-5">
                     {% if lang == 'en' %}
                     <div class="ev-section__tag d-inline-block mb-3">Portfolio</div>
                     <h2 class="about-pillars-title">End-to-end cybersecurity,<br>without depending on multiple vendors</h2>
                     <p class="about-pillars-subtitle">Evernow covers the four critical security fronts: from code to data, from audit to continuous operations, with certified specialists, 90-day delivery, and evidence for ISO 27001, LGPD, and PCI DSS.</p>
                     {% else %}
                     <div class="ev-section__tag d-inline-block mb-3">Portfólio</div>
                     <h2 class="about-pillars-title">Cibersegurança de ponta a ponta,<br>sem depender de múltiplos fornecedores</h2>
                     <p class="about-pillars-subtitle">A Evernow cobre as quatro frentes críticas de segurança, do código ao dado, da auditoria à operação contínua, com especialistas certificados, entrega em 90 dias e evidências para ISO 27001, LGPD e PCI DSS.</p>
                     {% endif %}
                  </div>
                  <div class="about-pillars-grid">

                     <div class="about-pillar-card wow fadeInUp">
                        <div class="about-card-icon"><i class="fas fa-code-branch"></i></div>
                        <h3>Secure Code</h3>
                        {% if lang == 'en' %}
                        <p class="about-pillar-desc">Security integrated into the development pipeline, from design to production.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> DevSecOps</li>
                           <li><i class="fas fa-check"></i> SAST / DAST / SCA</li>
                           <li><i class="fas fa-check"></i> Managed Secure Dev</li>
                           <li><i class="fas fa-check"></i> Threat Modeling</li>
                        </ul>
                        <a href="{{ urlPrefix }}/solucoes/secure-code/" class="about-pillar-link">View solutions <i class="fas fa-arrow-right"></i></a>
                        {% else %}
                        <p class="about-pillar-desc">Segurança integrada ao pipeline de desenvolvimento, do design à produção.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> DevSecOps</li>
                           <li><i class="fas fa-check"></i> SAST / DAST / SCA</li>
                           <li><i class="fas fa-check"></i> Dev Seguro Gerenciado</li>
                           <li><i class="fas fa-check"></i> Modelagem de Ameaças</li>
                        </ul>
                        <a href="/solucoes/secure-code/" class="about-pillar-link">Ver soluções <i class="fas fa-arrow-right"></i></a>
                        {% endif %}
                     </div>

                     <div class="about-pillar-card wow fadeInUp">
                        <div class="about-card-icon"><i class="fas fa-shield-alt"></i></div>
                        <h3>Data Shield</h3>
                        {% if lang == 'en' %}
                        <p class="about-pillar-desc">Protection and governance of sensitive data in hybrid and multi-cloud environments.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> Data Discovery</li>
                           <li><i class="fas fa-check"></i> DSPM</li>
                           <li><i class="fas fa-check"></i> DLP</li>
                           <li><i class="fas fa-check"></i> Encryption / KMS / HSM</li>
                        </ul>
                        <a href="{{ urlPrefix }}/solucoes/data-shield/" class="about-pillar-link">View solutions <i class="fas fa-arrow-right"></i></a>
                        {% else %}
                        <p class="about-pillar-desc">Proteção e governança de dados sensíveis em ambientes híbridos e multi-cloud.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> Data Discovery</li>
                           <li><i class="fas fa-check"></i> DSPM</li>
                           <li><i class="fas fa-check"></i> DLP</li>
                           <li><i class="fas fa-check"></i> Criptografia / KMS / HSM</li>
                        </ul>
                        <a href="/solucoes/data-shield/" class="about-pillar-link">Ver soluções <i class="fas fa-arrow-right"></i></a>
                        {% endif %}
                     </div>

                     <div class="about-pillar-card wow fadeInUp">
                        <div class="about-card-icon"><i class="fas fa-award"></i></div>
                        <h3>Assurance</h3>
                        {% if lang == 'en' %}
                        <p class="about-pillar-desc">Independent validation of security, compliance, and maturity.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> Pentest & Red Team</li>
                           <li><i class="fas fa-check"></i> Maturity Assessment</li>
                           <li><i class="fas fa-check"></i> GRC</li>
                           <li><i class="fas fa-check"></i> ISO 27001 / LGPD / PCI DSS</li>
                        </ul>
                        <a href="{{ urlPrefix }}/solucoes/assurance/" class="about-pillar-link">View solutions <i class="fas fa-arrow-right"></i></a>
                        {% else %}
                        <p class="about-pillar-desc">Validação independente de segurança, compliance e maturidade.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> Pentest & Red Team</li>
                           <li><i class="fas fa-check"></i> Assessment de Maturidade</li>
                           <li><i class="fas fa-check"></i> GRC</li>
                           <li><i class="fas fa-check"></i> ISO 27001 / LGPD / PCI DSS</li>
                        </ul>
                        <a href="/solucoes/assurance/" class="about-pillar-link">Ver soluções <i class="fas fa-arrow-right"></i></a>
                        {% endif %}
                     </div>

                     <div class="about-pillar-card wow fadeInUp">
                        <div class="about-card-icon"><i class="fas fa-cogs"></i></div>
                        <h3>Managed Ops</h3>
                        {% if lang == 'en' %}
                        <p class="about-pillar-desc">Continuous security with dedicated specialists and defined SLAs.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> SOC / Monitoring</li>
                           <li><i class="fas fa-check"></i> Managed Services</li>
                           <li><i class="fas fa-check"></i> Incident Response</li>
                           <li><i class="fas fa-check"></i> Vulnerability Management</li>
                        </ul>
                        <a href="{{ urlPrefix }}/solucoes/managed-ops/" class="about-pillar-link">View solutions <i class="fas fa-arrow-right"></i></a>
                        {% else %}
                        <p class="about-pillar-desc">Segurança contínua com especialistas dedicados e SLAs definidos.</p>
                        <ul class="about-pillar-list">
                           <li><i class="fas fa-check"></i> SOC / Monitoramento</li>
                           <li><i class="fas fa-check"></i> Serviços Gerenciados</li>
                           <li><i class="fas fa-check"></i> Resposta a Incidentes</li>
                           <li><i class="fas fa-check"></i> Gestão de Vulnerabilidades</li>
                        </ul>
                        <a href="/solucoes/managed-ops/" class="about-pillar-link">Ver soluções <i class="fas fa-arrow-right"></i></a>
                        {% endif %}
                     </div>

                  </div>
                  <div class="text-center mt-5">
                     <a href="{{ urlPrefix }}/contact.html" class="contact-btn">{{ "about.security_cards.btn" | t }}</a>
                  </div>
               </div>
            </div>
         </div>
      </div>
   </section>
</main>
