---
layout: layouts/base.njk
permalink: "/produtos/"
lang: pt
---
{% set seoTitle = "Portfólio de Produtos | Evernow Cybersecurity" %}
{% set seoDescription = "Conheça todo o portfólio da Evernow: 26 serviços e produtos de cibersegurança organizados em quatro pilares, Secure Code, Data Shield, Assurance e Managed Ops." %}
{% set breadcrumbs = [
  { label: "Início", url: "/" },
  { label: "Portfólio" }
] %}

<div class="header-and-banner-con w-100">
  <div class="header-and-banner-inner-con overlay-content">
    {% include "components/header.njk" %}

    {% include "components/breadcrumbs.njk" %}

    <section class="banner-main-con ev-hero">
      <div class="container">
        <div class="row">
          <div class="col-lg-9 col-md-11">
            <div class="banner-left-con wow slideInLeft">
              <p style="color:#00e0a3;font-size:.78rem;text-transform:uppercase;letter-spacing:.1em;font-weight:700;margin-bottom:12px;">Portfólio</p>
              <h1>Tudo que a Evernow entrega</h1>
              <p class="ev-hero__sub">{{ solutions | length }} pilares. 26 serviços especializados. Um único parceiro para o seu programa de cibersegurança, do código ao SOC.</p>
              <div class="banner-btn mt-4" style="display:flex;gap:16px;flex-wrap:wrap;">
                <a href="/contact.html" class="contact-btn">Fale com um especialista</a>
                <a href="/assessment.html" class="ev-btn-outline">Fazer o assessment</a>
              </div>
              <div class="ev-hero__trust mt-4">
                <span class="ev-hero__trust-item"><i class="fas fa-check-circle"></i> Especialistas certificados</span>
                <span class="ev-hero__trust-item"><i class="fas fa-check-circle"></i> Resultados em 90 dias</span>
                <span class="ev-hero__trust-item"><i class="fas fa-check-circle"></i> Agnóstico de plataforma</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

<main>

  {# ── Índice rápido de pilares ── #}
  <section style="border-bottom:1px solid rgba(255,255,255,.07);padding:28px 0;">
    <div class="container overlay-content">
      <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center;">
        {%- for sol in solutions -%}
        <a href="#pilar-{{ sol.slug }}"
           style="display:inline-flex;align-items:center;gap:8px;padding:8px 20px;border:1px solid rgba(255,255,255,.15);border-radius:24px;color:rgba(255,255,255,.75);text-decoration:none;font-size:.85rem;font-weight:600;transition:border-color .2s,color .2s;"
           onmouseover="this.style.borderColor='#00e0a3';this.style.color='#00e0a3';"
           onmouseout="this.style.borderColor='rgba(255,255,255,.15)';this.style.color='rgba(255,255,255,.75)';">
          {%- if sol.slug == 'secure-code' -%}<i class="fas fa-code" style="color:#00e0a3;font-size:.8rem;"></i>
          {%- elif sol.slug == 'data-shield' -%}<i class="fas fa-shield-alt" style="color:#00e0a3;font-size:.8rem;"></i>
          {%- elif sol.slug == 'assurance' -%}<i class="fas fa-check-double" style="color:#00e0a3;font-size:.8rem;"></i>
          {%- else -%}<i class="fas fa-cogs" style="color:#00e0a3;font-size:.8rem;"></i>
          {%- endif -%}
          {{ sol.titulo }}
        </a>
        {%- endfor -%}
      </div>
    </div>
  </section>

  {# ── Um bloco por pilar ── #}
  {%- for sol in solutions -%}
  <section id="pilar-{{ sol.slug }}" class="ev-section {% if loop.index is odd %}bg-overly-img{% else %}ev-section--alt{% endif %}">
    <div class="container overlay-content">

      {# Cabeçalho do pilar #}
      <div class="ev-products-pilar-header wow fadeInUp">
        <div class="ev-products-pilar-header__left">
          <a href="/solucoes/{{ sol.slug }}/" class="ev-products-pilar__link">
            {%- if sol.slug == 'secure-code' -%}<i class="fas fa-code"></i>
            {%- elif sol.slug == 'data-shield' -%}<i class="fas fa-shield-alt"></i>
            {%- elif sol.slug == 'assurance' -%}<i class="fas fa-check-double"></i>
            {%- else -%}<i class="fas fa-cogs"></i>
            {%- endif -%}
            {{ sol.titulo }}
          </a>
          <h2 class="ev-products-pilar__title">{{ sol.tagline }}</h2>
          <p class="ev-products-pilar__desc">{{ sol.descricao }}</p>
        </div>
        <a href="/solucoes/{{ sol.slug }}/" class="ev-products-pilar__cta-link">
          Ver solução completa <i class="fas fa-arrow-right"></i>
        </a>
      </div>

      {# Grade de produtos do pilar #}
      <div class="ev-pilar-product-grid">
        {%- for prod in sol.produtos -%}
        <a href="/produtos/{{ prod.slug }}/" class="ev-pilar-product wow fadeInUp">
          <div class="ev-pilar-product__icon">
            <i class="{{ prod.icon if prod.icon else 'fas fa-shield-alt' }}"></i>
          </div>
          <div class="ev-pilar-product__body">
            <h5>{{ prod.titulo }}</h5>
            <p class="ev-pilar-product__tagline">{{ prod.tagline }}</p>
            <ul class="ev-pilar-product__features">
              {%- for feat in prod.features -%}
              <li><i class="fas fa-check"></i> {{ feat }}</li>
              {%- endfor -%}
            </ul>
          </div>
          <span class="ev-pilar-product__cta">Ver detalhes <i class="fas fa-arrow-right"></i></span>
        </a>
        {%- endfor -%}
      </div>

    </div>
  </section>
  {%- endfor -%}

  {# ── CTA Final ── #}
  {% set ctaTitle = "Não sabe por onde começar?" %}
  {% set ctaSubtitle = "Nosso assessment mapeia lacunas, prioriza riscos e define o roadmap certo para sua empresa." %}
  {% set ctaPrimary = "Fale com um especialista" %}
  {% set ctaSecondary = "Fazer o assessment gratuito" %}
  {% include "components/cta-final.njk" %}

</main>
