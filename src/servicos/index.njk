---
layout: layouts/base.njk
pagination:
  data: languages
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/en/services/{% else %}/servicos/{% endif %}"
seoTitle: "Serviços de Consultoria em Cibersegurança | Evernow"
seoDescription: "LGPD, ISO 27001, PCI-DSS, resposta a incidentes, DPO as a Service e mais: serviços de consultoria e compliance executados por especialistas sêniores."
seoKeywords: "consultoria cibersegurança, serviços compliance, dpo as a service, adequação lgpd, iso 27001, pci dss"
langPtUrl: "/servicos/"
langEnUrl: "/en/services/"
---
{% set urlPrefix = "" if lang == "pt" else "/en" %}
{% set langPtUrl = "/servicos/" %}
{% set langEnUrl = "/en/services/" %}
{% set breadcrumbs = [
  { label: ("Home" if lang == "en" else "Início"), url: urlPrefix + "/" },
  { label: ("Services" if lang == "en" else "Serviços") }
] %}

<div class="header-and-banner-con w-100">
  <div class="header-and-banner-inner-con overlay-content">
    {% include "components/header.njk" %}
    {% include "components/breadcrumbs.njk" %}
    <section class="banner-main-con">
      <div class="container">
        <div class="banner-con">
          <div class="row align-items-center">
            <div class="col-lg-9">
              <p style="color:#00e0a3;font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;font-weight:700;margin-bottom:12px;">{% if lang == "en" %}Services{% else %}Serviços{% endif %}</p>
              <h1>{% if lang == "en" %}Commercial services and consulting programs{% else %}Serviços e programas de consultoria{% endif %}</h1>
              <p style="color:rgba(255,255,255,.85);max-width:820px;">{% if lang == "en" %}Structured programs with timeline, deliverables and KPIs. Pair a program with one or more products to form a full security posture.{% else %}Programas estruturados com cronograma, entregáveis e KPIs. Combine um programa com um ou mais produtos para compor uma postura completa.{% endif %}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

<main>
  <section class="ev-section">
    <div class="container">
      <div class="ev-section__tag wow fadeInUp">{% if lang == "en" %}Programs{% else %}Programas{% endif %}</div>
      <h2 class="ev-section__title wow fadeInUp">{% if lang == "en" %}Flagship programs{% else %}Programas de destaque{% endif %}</h2>
      <div class="row mt-4">
        <div class="col-md-6 mb-4">
          <a href="{{ urlPrefix }}/servicos/adequacao-lgpd/" style="display:block;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:26px;text-decoration:none;height:100%;">
            <p style="color:#00e0a3;font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;font-weight:700;">Compliance</p>
            <h4 style="color:#fff;">{% if lang == "en" %}LGPD Compliance{% else %}Adequação LGPD{% endif %}</h4>
            <p style="color:rgba(255,255,255,.7);font-size:.92rem;">{% if lang == "en" %}120-day roadmap, DPO as a Service, 14 concrete deliverables, ANPD-ready.{% else %}Roadmap em 120 dias, DPO as a Service, 14 entregáveis concretos, pronto para ANPD.{% endif %}</p>
          </a>
        </div>

        <div class="col-md-6 mb-4">
          <a href="{{ urlPrefix }}/servicos/soc-como-servico/" style="display:block;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:26px;text-decoration:none;height:100%;">
            <p style="color:#00e0a3;font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;font-weight:700;">Managed Ops</p>
            <h4 style="color:#fff;">{% if lang == "en" %}SOC as a Service 24x7{% else %}SOC como Serviço 24x7{% endif %}</h4>
            <p style="color:rgba(255,255,255,.7);font-size:.92rem;">{% if lang == "en" %}Brazilian analysts, contractual SLA with penalties, 30-day onboarding, platform-agnostic.{% else %}Analistas brasileiros, SLA contratual com penalidade, onboarding em 30 dias, agnóstico de plataforma.{% endif %}</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  {% set ctaTitle = ("Not sure which program is right for you?" if lang == "en" else "Não sabe qual programa é o certo?") %}
  {% set ctaSubtitle = ("30-minute call with a senior specialist — we'll shape a plan that fits your context." if lang == "en" else "30 min com um especialista sênior — desenhamos um plano sob medida para seu contexto.") %}
  {% set ctaPrimary = ("Talk to a specialist" if lang == "en" else "Fale com um especialista") %}
  {% set ctaSecondary = ("Take the free assessment" if lang == "en" else "Fazer assessment gratuito") %}
  {% include "components/cta-final.njk" %}
</main>
