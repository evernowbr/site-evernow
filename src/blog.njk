---js
{
  layout: "layouts/base.njk",
  useBlogStyles: true,
  pageMeta: "blog",
  pagination: {
    data: "blogListPages",
    size: 1,
    alias: "listPage"
  },
  permalink: function(data) {
    const lp     = data.listPage;
    const prefix = lp && lp.lang === 'en' ? '/en' : '';
    const n      = lp && lp.pageNum;
    return (!n || n === 1) ? `${prefix}/blog.html` : `${prefix}/blog/pagina-${n}.html`;
  },
  eleventyComputed: {
    lang: (data) => (data.listPage && data.listPage.lang) || 'pt'
  }
}
---
<div class="header-and-banner-con w-100">
   <div class="header-and-banner-inner-con overlay-content">
      {% include "components/header.njk" %}

      <section class="banner-main-con about-page-main-banner-con post-banner">
         <div class="container">
            <div class="banner-con about-page-banner-con text-center">
               <div class="row wow slideInLeft">
                  <div class="col-lg-12">
                     <div class="about-page-banner-title">
                        <h1 class="post-banner-title blog-index-title">{{ "blog.banner.title" | t }}</h1>
                        <p class="blog-banner-subtitle mb-0">{{ "blog.banner.subtitle" | t }}</p>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </section>
   </div>
</div>

<main>
   <section class="post-section py-5">
      <div class="container">

         {# ── White card wrapper ───────────────────────────────── #}
         <div class="blog-layout">

            {# ── Post grid ─────────────────────────────────────── #}
            <div class="row" id="blog">
               {% for post in listPage.posts %}
               <div class="col-xl-4 col-lg-4 col-md-6 mb-4 d-flex">
                  <div class="w-100 d-flex flex-column blog-card">

                     {# Featured image (only when a real image exists) #}
                     {% if post.featuredImage %}
                     <div class="post-image">
                        <a href="{{ urlPrefix }}/blog/{{ post.slug }}.html">
                           <img src="{{ post.featuredImage }}"
                                alt="{{ post.title }}"
                                loading="lazy"
                                class="blog-card__img">
                        </a>
                     </div>
                     {% endif %}

                     {# Card body #}
                     <div class="blog-card__body d-flex flex-column flex-grow-1">

                        {# Date #}
                        <span class="blog-card__date">
                           <i class="fa fa-calendar-o mr-1"></i>
                           {% if lang == 'en' %}{{ post.dateEn }}{% else %}{{ post.datePt }}{% endif %}
                        </span>

                        {# Title #}
                        <h2 class="blog-card__title">
                           <a href="{{ urlPrefix }}/blog/{{ post.slug }}.html">{{ post.title }}</a>
                        </h2>

                        {# Excerpt #}
                        <p class="blog-card__excerpt flex-grow-1">{{ post.excerpt }}</p>

                        {# Read more #}
                        <a href="{{ urlPrefix }}/blog/{{ post.slug }}.html" class="blog-card__readmore">
                           {{ "blog.posts.read_more" | t }} <i class="fa fa-arrow-right"></i>
                        </a>
                     </div>

                  </div>
               </div>
               {% endfor %}
            </div>

            {# ── Pagination ────────────────────────────────────── #}
            {% if listPage.totalPages > 1 %}
            <nav aria-label="{{ 'Blog pagination' if lang == 'en' else 'Paginação do blog' }}" class="blog-layout__pagination">
               <ul class="pagination justify-content-center flex-wrap mb-0">

                  <li class="page-item {% if not listPage.prevUrl %}disabled{% endif %}">
                     <a class="page-link"
                        href="{{ listPage.prevUrl or '#' }}"
                        {% if not listPage.prevUrl %}aria-disabled="true" tabindex="-1"{% endif %}>
                        <i class="fa fa-chevron-left"></i>
                     </a>
                  </li>

                  {% for n in range(1, listPage.totalPages + 1) %}
                  {% set pgUrl = (urlPrefix or '') + '/blog' + ('/pagina-' + n if n > 1 else '') + '.html' %}
                  <li class="page-item {% if n == listPage.pageNum %}active{% endif %}">
                     <a class="page-link" href="{{ pgUrl }}">{{ n }}</a>
                  </li>
                  {% endfor %}

                  <li class="page-item {% if not listPage.nextUrl %}disabled{% endif %}">
                     <a class="page-link"
                        href="{{ listPage.nextUrl or '#' }}"
                        {% if not listPage.nextUrl %}aria-disabled="true" tabindex="-1"{% endif %}>
                        <i class="fa fa-chevron-right"></i>
                     </a>
                  </li>

               </ul>
            </nav>
            {% endif %}

         </div>{# /blog-layout #}

      </div>
   </section>
</main>
