---
layout: layouts/base.njk
pagination:
  data: languages
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/en/{% endif %}solutions.html"
useBlogStyles: true
pageMeta: solutions
---
<div class="header-and-banner-con w-100">
   <div class="header-and-banner-inner-con overlay-content">
      {% include "components/header.njk" %}
      
      <section class="banner-main-con about-page-main-banner-con">
         <div class="container">
            <div class="banner-con about-page-banner-con text-center">
               <div class="row wow slideInLeft">
                  <div class="col-lg-12">
                     <div class="about-page-banner-title">
                        <h1>{{ "solutions.banner.title" | t }}</h1>
                        <p class="mb-0">{{ "solutions.banner.subtitle" | t }}</p>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </section>
   </div>
</div>

<main>
   <section class="padding_top_120 padding_bottom_65 blog-posts">
      <div class="container">
         <div class="row">
            <div id="blog" class="three-column col-xl-12">
               <div class="row">
                  {% for i in range(1, 7) %}
                  <div class="col-xl-4 col-lg-4">
                     <div class="float-left w-100 post-item border mb-4">
                        <div class="post-item-wrap position-relative">
                           <div class="post-image">
                              <a href="#"><img src="{{ ('solutions.grid.item' ~ i ~ '.img') | t }}" alt=""></a>
                              <span class="post-meta-category">
                                 <a href="">{{ ('solutions.grid.item' ~ i ~ '.category') | t }}</a>
                              </span>
                           </div>
                           <div class="post-item-description">
                              <span class="post-meta-date">{{ ('solutions.grid.item' ~ i ~ '.tag') | t }}</span>
                              <h2><a href="#">{{ ('solutions.grid.item' ~ i ~ '.title') | t }}</a></h2>
                              <p>{{ ('solutions.grid.item' ~ i ~ '.desc') | t | safe }}</p>
                           </div>
                        </div>
                     </div>
                  </div>
                  {% endfor %}
               </div>
            </div>
         </div>
      </div>
   </section>

   <!-- Logo Carousel -->
   {% set partnersTagKey = "solutions.partners.tag" | t %}
   {% set partnersAriaLabel = "Partner Logos" %}
   {% include "components/partners-carousel.njk" %}
</main>
